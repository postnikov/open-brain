# Required: OpenAI API key for embeddings and metadata extraction
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Database connection string
# If using Docker Compose, this is auto-configured — no need to change
DATABASE_URL=postgresql://open_brain:open_brain_local@localhost:5432/open_brain

# Server port (default: 3100)
PORT=3100
